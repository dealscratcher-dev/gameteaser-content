# ============================================================
# .dockerignore  – repo root
# Keep Docker build context lean and fast
# ============================================================

# Version control
.git
.gitignore

# Local env files (never bake secrets into images)
**/.env
**/.env.local
**/.env*.local

# Node
**/node_modules
**/.pnpm-store

# Next.js build output and caches
**/.next
**/out

# Turborepo and standard caches
**/.turbo
**/.cache

# Test & lint
**/__tests__
**/*.test.ts
**/*.spec.ts
**/.eslintcache
**/coverage

# Docs & scripts not needed at runtime
README.md
DEPLOY-NOW.md
ADSENSE-SETUP.md
TAXONOMY.md
push-to-github.ps1
scripts/serve.js

# macOS & OS Generated
.DS_Store
**/.DS_Store
Thumbs.db

# Editor
.vscode
.idea
*.swp
*.swo

# CI/CD and deployment
.github
.netlify
.vercel
